generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  duration    Int      // 1, 7, 30, 365 days
  price       Decimal  @db.Decimal(10, 2)
  cardType    String   @map("card_type") // "1d", "7d", "30d", "365d"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders      Order[]

  @@map("products")
}

model Card {
  id          String    @id @default(cuid())
  cardCode    String    @unique @map("card_code") // 加密存儲
  cardType    String    @map("card_type") // "1d", "7d", "30d", "365d"
  status      Int       @default(0) // 0=未使用, 1=已使用
  orderId     String?   @map("order_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  usedAt      DateTime? @map("used_at")

  order       Order?    @relation(fields: [orderId], references: [id])

  @@index([cardType, status])
  @@map("cards")
}

model Order {
  id          String    @id @default(cuid())
  orderNo     String    @unique @map("order_no") // CARD20260405001
  email       String
  productId   String    @map("product_id")
  amount      Decimal   @db.Decimal(10, 2)
  cardType    String    @map("card_type")
  payMethod   String?   @map("pay_method") // alipayhk, wechatpay, fps, payme
  payStatus   Int       @default(0) @map("pay_status") // 0=未支付, 1=已支付, 2=已取消
  cardId      String?   @map("card_id")
  paidAt      DateTime? @map("paid_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  product     Product   @relation(fields: [productId], references: [id])
  card        Card?

  @@index([orderNo])
  @@index([payStatus])
  @@map("orders")
}

model PayLog {
  id          String   @id @default(cuid())
  orderNo     String   @map("order_no")
  amount      Decimal  @db.Decimal(10, 2)
  method      String   // 支付方式
  verified    Boolean  @default(false)
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orderNo])
  @@map("pay_logs")
}

model AdminLog {
  id          String   @id @default(cuid())
  action      String   // import_cards, manual_confirm, etc.
  details     String?
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("admin_logs")
}
